#!/bin/sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_DIR=$(dirname -- "$SCRIPT_DIR")
export PYTHONPATH="$REPO_DIR/src${PYTHONPATH:+:$PYTHONPATH}"

if [ "${CODEX_DYNAMICFLOW_PYTHON:-}" ]; then
  PYTHON_BIN=$CODEX_DYNAMICFLOW_PYTHON
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN=$(command -v python3)
elif command -v xcrun >/dev/null 2>&1 && xcrun --find python3 >/dev/null 2>&1; then
  PYTHON_BIN=$(xcrun --find python3)
else
  echo "codex-dynamicflow-mcp: python3 not found" >&2
  exit 127
fi

exec "$PYTHON_BIN" -m codex_dynamicflow.mcp_server
